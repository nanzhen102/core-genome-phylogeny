params {
    accessions   = "inputs/accessions.csv"
    outgroup     = "inputs/outgroup.csv"
    outdir       = "results"
    identity     = 60
    cpus_prokka  = 8
    cpus_roary   = 16
}

conda {
    enabled         = true
    channelPriority = 'strict'
}

report {
    enabled   = true
    file      = "${params.outdir}/report.html"
    overwrite = true
}

process {
    executor = 'local'

    withName: 'DOWNLOAD' {
        container = 'biocontainers/ncbi-datasets-cli:latest'
    }
    withName: 'PROKKA' {
        container = 'staphb/prokka:1.14.6'
    }
    withName: 'ROARY' {
        container = 'sangerpathogens/roary:3.13.0'
    }
    withName: 'FASTTREE' {
        container = 'biocontainers/fasttree:v2.1.10dfsg-2-deb_cv1'
    }
}

profiles {
    slurm {
        process.executor = 'slurm'
        conda.enabled    = true

        withName: 'DOWNLOAD' {
            time   = '1h'
            cpus   = 2
            memory = '8 GB'
        }
        withName: 'PROKKA' {
            time   = '2h'
            cpus   = 8
            memory = '16 GB'
        }
        withName: 'ROARY' {
            time   = '12h'
            cpus   = 16
            memory = '64 GB'
        }
        withName: 'FASTTREE' {
            time   = '4h'
            cpus   = 8
            memory = '32 GB'
        }
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    docker {
        docker.enabled = true
    }
    local {
        process.executor = 'local'
        conda.enabled    = true
    }
    test {
        params.accessions = "inputs/test_accessions.csv"
        params.outgroup   = "inputs/test_outgroup.csv"
    }
}